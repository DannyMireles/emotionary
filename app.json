{
  "expo": {
    "name": "Emotionary",
    "slug": "emotionary",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "emotionary",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.emotionary.app",
      "buildNumber": "2026072002",
      "supportsTablet": false
    },
    "android": {
      "package": "com.emotionary.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F0",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF7F0",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      "expo-notifications",
      [
        "expo-media-library",
        {
          "photosPermission": false,
          "savePhotosPermission": "Allow Emotionary to save word cards to your photos.",
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      "expo-sharing",
      "@react-native-community/datetimepicker",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.emotionary.app.widgets",
          "groupIdentifier": "group.com.emotionary.app",
          "widgets": [
            {
              "name": "DailyWord",
              "displayName": "Emotionary Daily Word",
              "description": "Keep today's emotion word close on your Home or Lock Screen.",
              "ios": {
                "supportedFamilies": [
                  "systemSmall",
                  "systemMedium",
                  "accessoryCircular",
                  "accessoryRectangular",
                  "accessoryInline"
                ]
              }
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
