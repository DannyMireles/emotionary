# Supabase connection (safe to ship in the app — publishable key + RLS).
# Copy to .env and fill in after `supabase link` / project creation.
# Leave unset to run fully offline from the bundled seed.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-side only — for scripts/import-manuscript.ts. NEVER ship in the app.
# SUPABASE_SECRET_KEY=sb_secret_...
